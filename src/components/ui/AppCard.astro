---
/* src/components/ui/AppCard.astro */
interface Props {
  title: string;
  description: string;
  href: string;
  github?: string; // Optional prop
}

const { title, description, href, github } = Astro.props;
---

<div class="flex flex-col p-6 rounded-xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-900 shadow-lg hover:border-blue-500 transition-colors">
  <h3 class="text-2xl font-bold mb-2">{title}</h3>
  <p class="text-muted dark:text-slate-400 mb-6">
    {description}
  </p>
  
  <div class="mt-auto flex flex-wrap gap-3">
    <a href={href} class="btn-primary py-2 px-5 rounded-lg font-semibold inline-block">
      Launch App
    </a>
    
    {github && (
      <a 
        href={github} 
        target="_blank" 
        rel="noopener noreferrer"
        class="btn-secondary py-2 px-5 rounded-lg font-semibold inline-block border border-gray-300 dark:border-slate-700 hover:bg-gray-100 dark:hover:bg-slate-800 transition"
      >
        Source Code
      </a>
    )}
  </div>
</div>